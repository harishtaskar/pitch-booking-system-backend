# PostgreSQL connection string (read by prisma.config.ts and the pg driver adapter).
# For a hosted DB over TLS (e.g. Neon), append `&uselibpqcompat=true` so the
# node-postgres driver keeps libpq-compatible sslmode behaviour, e.g.:
#   postgresql://USER:PASS@HOST/db?sslmode=require&uselibpqcompat=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pitch_booking?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
# Allowed CORS origin(s). Comma-separate to allow several, e.g.
# "http://localhost:5173,https://myapp.com". In development any localhost port
# is allowed automatically.
CLIENT_ORIGIN="http://localhost:5173"

# Reservation hold duration in seconds (2 minutes)
RESERVATION_TTL_SECONDS=120